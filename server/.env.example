# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# The Gmail account used to SEND all emails (must have 2-Step Verification on)
EMAIL_USER=aerotechsolutions@gmail.com

# Generate at: https://myaccount.google.com/apppasswords
# Select "Mail" + "Other (custom name)" → copy the 16-character password
EMAIL_PASS=your_16_char_app_password_here

# ─── Routing ──────────────────────────────────────────────────────────────────
# The inbox that receives contact form submissions and booking notifications
# Defaults to EMAIL_USER when not set
COMPANY_EMAIL=aerotechsolutions@gmail.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend domain — restrict this in production
# Example: https://aerotechsolutioninc.com
ALLOWED_ORIGIN=*
