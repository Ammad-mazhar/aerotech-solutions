# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# The Gmail account used to SEND all emails (must have 2-Step Verification on)
EMAIL_USER=aerotechsolutions@gmail.com

# Generate at: https://myaccount.google.com/apppasswords
# Select "Mail" + "Other (custom name)" → copy the 16-character password
EMAIL_PASS=your_16_char_app_password_here

# ─── Routing ──────────────────────────────────────────────────────────────────
# The inbox that receives contact form submissions
# Defaults to EMAIL_USER when not set
COMPANY_EMAIL=aerotechsolutions@gmail.com

# The inbox that receives service booking notifications (falls back to
# COMPANY_EMAIL, then EMAIL_USER, if not set)
RECEIVER_EMAIL=aerotechsolutions@gmail.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGIN=https://aerotechsolutioninc.com,https://www.aerotechsolutioninc.com
